---
export interface Props {
  eyebrow?: string;
  title: string;
  lede: string;
  items?: string[];
  note?: string;
}

const { eyebrow = 'Placeholder', title, lede, items = [], note } = Astro.props;
---
<section class="py-12 md:py-20">
  <div class="max-w-3xl">
    <p class="text-sm uppercase tracking-[0.15em] text-ink-muted mb-4 m-0">{eyebrow}</p>
    <h1 class="text-4xl md:text-5xl leading-tight mb-6 mt-0">{title}</h1>
    <p class="text-xl text-ink-muted leading-relaxed mb-10 max-w-prose">{lede}</p>
    {items.length > 0 && (
      <>
        <h2 class="text-xl mb-4 mt-0">Wat hier komt te staan</h2>
        <ul class="space-y-2 list-disc pl-6 text-ink-muted max-w-prose mb-6">
          {items.map((item) => <li>{item}</li>)}
        </ul>
      </>
    )}
    {note && (
      <p class="text-sm text-ink-muted border-l-2 border-accent-soft pl-4 italic">{note}</p>
    )}
  </div>
</section>
