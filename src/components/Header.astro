---
import { url } from '../lib/url.ts';

const nav = [
  { href: '/over/', label: 'Over' },
  { href: '/leeruitkomsten/', label: 'Wat je leert' },
  { href: '/architectuur/', label: 'Programma' },
  { href: '/weken/', label: 'Per week' },
  { href: '/casussen/', label: 'Casussen' },
  { href: '/aanmelden/', label: 'Aanmelden' },
];

const current = Astro.url.pathname;
---
<header class="border-b border-rule">
  <div class="mx-auto max-w-5xl px-4 md:px-6 py-4 md:py-5 flex flex-col md:flex-row md:items-center md:justify-between gap-3 md:gap-6">
    <a
      href={url('/')}
      class="font-serif text-xl md:text-[1.35rem] no-underline text-ink hover:text-accent"
    >
      AI-geletterdheid <span class="text-ink-muted text-base font-sans">· Fontys CE</span>
    </a>
    <nav aria-label="Hoofdnavigatie">
      <ul class="flex flex-wrap gap-x-5 gap-y-2 text-[0.95rem] list-none p-0 m-0">
        {nav.map((item) => {
          const href = url(item.href);
          const isActive = current === href || (item.href !== '/' && current.startsWith(href));
          return (
            <li>
              <a
                href={href}
                aria-current={isActive ? 'page' : undefined}
                class:list={[
                  'no-underline',
                  isActive ? 'text-accent font-medium' : 'text-ink hover:text-accent',
                ]}
              >
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>
