---
import { url } from '../lib/url.ts';

export interface Props {
  variant?: 'horizontal' | 'full';
  height?: number;
  class?: string;
}

const { variant = 'horizontal', height = 44, class: className = '' } = Astro.props;

// variant "horizontal" = compacte "ai"-ligatuur met schaalbalk; past in de header
// variant "full" = volledig logo met wordmark, voor hero of marketingcontext
const src = variant === 'full' ? url('/logo-horizontal.png') : url('/logo-mark.png');
---
<img
  src={src}
  alt="AI-geletterd · Fontys Commerciële Economie"
  height={height}
  style={`height: ${height}px; width: auto;`}
  class:list={['block select-none', className]}
  draggable="false"
/>
