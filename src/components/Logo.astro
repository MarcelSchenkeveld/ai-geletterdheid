---
export interface Props {
  variant?: 'horizontal' | 'stacked' | 'mark';
  markSize?: number;
  class?: string;
}

const { variant = 'horizontal', markSize = 38, class: className = '' } = Astro.props;

// Beeldmerk: een serif-ampersand. Betekent "en" — jij & AI, kennis & oordeel,
// vraag & antwoord. Typografisch fossiel (ligatuur van Latijn "et"), daarmee
// verlengde van de serif-typografie van de site. Geen tech-cliché.
const markBoxStyle = `width: ${markSize}px; height: ${markSize}px;`;
const markGlyphStyle = `font-size: ${Math.round(markSize * 0.7)}px; line-height: 1; padding-bottom: 0.05em;`;
---
{variant === 'horizontal' && (
  <span class:list={['inline-flex items-center gap-3 md:gap-4', className]}>
    <span
      class="inline-flex items-center justify-center rounded-md bg-accent text-bg font-serif italic flex-shrink-0"
      style={`${markBoxStyle} ${markGlyphStyle}`}
      aria-hidden="true"
    >&amp;</span>
    <span class="leading-none">
      <span class="block font-serif text-xl md:text-[1.35rem] text-ink leading-none">AI-geletterdheid</span>
      <span class="block text-[0.68rem] md:text-xs text-ink-muted uppercase tracking-[0.12em] mt-1.5 font-sans font-medium">Fontys Commerciële Economie</span>
    </span>
  </span>
)}
{variant === 'stacked' && (
  <span class:list={['inline-flex flex-col items-center gap-3', className]}>
    <span
      class="inline-flex items-center justify-center rounded-md bg-accent text-bg font-serif italic"
      style={`${markBoxStyle} ${markGlyphStyle}`}
      aria-hidden="true"
    >&amp;</span>
    <span class="text-center leading-none">
      <span class="block font-serif text-2xl md:text-3xl text-ink leading-none">AI-geletterdheid</span>
      <span class="block text-xs md:text-sm text-ink-muted uppercase tracking-[0.12em] mt-2 font-sans font-medium">Fontys Commerciële Economie</span>
    </span>
  </span>
)}
{variant === 'mark' && (
  <span
    class:list={['inline-flex items-center justify-center rounded-md bg-accent text-bg font-serif italic', className]}
    style={`${markBoxStyle} ${markGlyphStyle}`}
    role="img"
    aria-label="AI-geletterdheid beeldmerk"
  >&amp;</span>
)}
