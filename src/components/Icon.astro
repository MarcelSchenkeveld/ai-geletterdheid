---
export interface Props {
  name: string;
  size?: number;
  class?: string;
  label?: string;
}

const { name, size = 24, class: className = '', label } = Astro.props;
const a11y = label
  ? { role: 'img', 'aria-label': label }
  : { 'aria-hidden': 'true', focusable: 'false' };
---
<svg
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.5"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  {...a11y}
>
  {name === 'compass' && (
    <>
      <circle cx="12" cy="12" r="8.5" />
      <path d="M15.2 8.8 13 13l-4.2 2.2L11 11z" fill="currentColor" stroke="none" />
    </>
  )}
  {name === 'calendar' && (
    <>
      <rect x="3.5" y="5" width="17" height="15" rx="1.5" />
      <path d="M3.5 10h17" />
      <path d="M8 3.5v3" />
      <path d="M16 3.5v3" />
    </>
  )}
  {name === 'layers' && (
    <>
      <path d="M12 3.5 3 8l9 4.5L21 8z" />
      <path d="M3 13l9 4.5L21 13" />
      <path d="M3 17.5 12 22l9-4.5" />
    </>
  )}
  {name === 'users' && (
    <>
      <circle cx="9" cy="9" r="3.25" />
      <path d="M3 19.5c0-3.3 2.7-6 6-6s6 2.7 6 6" />
      <circle cx="17" cy="10.5" r="2.5" />
      <path d="M15 19.5c0-2.2 1.8-4 4-4h1.5" />
    </>
  )}
  {name === 'clock' && (
    <>
      <circle cx="12" cy="12" r="8.5" />
      <path d="M12 7.5V12l3 2" />
    </>
  )}
  {name === 'target' && (
    <>
      <circle cx="12" cy="12" r="8.5" />
      <circle cx="12" cy="12" r="4.5" />
      <circle cx="12" cy="12" r="1.25" fill="currentColor" stroke="none" />
    </>
  )}
  {name === 'check' && (
    <>
      <circle cx="12" cy="12" r="8.5" />
      <path d="m8 12.5 2.5 2.5 5.5-5.5" />
    </>
  )}
  {name === 'mail' && (
    <>
      <rect x="3.5" y="5.5" width="17" height="13" rx="1.5" />
      <path d="m4 7 8 5.5L20 7" />
    </>
  )}
  {name === 'document' && (
    <>
      <path d="M6 3.5h7.5L18 8v11a1.5 1.5 0 0 1-1.5 1.5h-10.5A1.5 1.5 0 0 1 4.5 19V5A1.5 1.5 0 0 1 6 3.5z" />
      <path d="M13 3.5V8h5" />
      <path d="M8 13h7" />
      <path d="M8 16.5h5" />
    </>
  )}
  {name === 'arrow-right' && (
    <>
      <path d="M4.5 12h14.5" />
      <path d="m13 6 6 6-6 6" />
    </>
  )}
  {name === 'signpost' && (
    <>
      <path d="M12 3.5v17" />
      <path d="M6 7 4 9l2 2h12V7z" />
      <path d="m18 13 2 2-2 2H6v-4z" />
    </>
  )}
  {name === 'flag' && (
    <>
      <path d="M5 21V4.5" />
      <path d="M5 5h11l-2 3.5L16 12H5" />
    </>
  )}
</svg>
