---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import TijdlijnSchema from '../../components/TijdlijnSchema.astro';
import { url } from '../../lib/url.ts';
import { weken } from '../../data/weken.ts';

const vaardigheden = [
  {
    titel: 'AI inzetten in commerciële vraagstukken',
    tekst: 'Passende AI-toepassing kiezen, sturen op bruikbare output, beoordelen of het past bij wat je opdrachtgever nodig heeft.',
    icon: 'target',
  },
  {
    titel: 'Kritisch en creatief denken met AI',
    tekst: 'AI gebruiken om scherper en breder te denken, in plaats van AI je denkwerk te laten overnemen.',
    icon: 'compass',
  },
  {
    titel: 'Regie en verantwoord AI-gebruik',
    tekst: 'Navolgbaar maken hoe je AI hebt ingezet, ethische afwegingen kunnen toelichten, zelf de regie houden.',
    icon: 'check',
  },
];
---
<BaseLayout
  title="Programma-opbouw"
  description="Zeven werkweken, één doorlopende opdracht voor Brouwerij De Vier Vaten, en twee vertaalslagen naar je eigen Business Challenge."
>
  <section class="py-12 md:py-16">
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-[0.15em] text-ink-muted mb-4 m-0">Programma-opbouw</p>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-6 mt-0">Zo ziet het programma eruit</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-0 max-w-prose">
        Zeven werkweken in de structuur 1 + 3 + 2 + 1. Eén plenaire startbijeenkomst, vijf weken werken aan een doorlopende opdracht voor Brouwerij De Vier Vaten, en een plenaire afronding. Tussendoor twee vertaalslagen naar je eigen Business Challenge.
      </p>
    </div>
  </section>

  <section class="py-8 md:py-10 border-t border-rule">
    <div class="max-w-5xl">
      <TijdlijnSchema />
    </div>
  </section>

  <section class="py-10 md:py-12 border-t border-rule">
    <div class="max-w-3xl">
      <div class="border-l-4 border-accent pl-5 max-w-prose">
        <h2 class="text-xl md:text-2xl mt-0 mb-3 font-sans font-semibold text-ink">Eén opdrachtgever, vijf weken, twee oplevermomenten</h2>
        <p class="text-lg leading-relaxed m-0">
          Casus 1 en casus 2 zijn geen twee losse opdrachten. Je werkt vijf werkweken lang aan één doorlopend dossier voor Brouwerij De Vier Vaten. Casus 1 is je eerste opdracht (week 2 tot en met 4); casus 2 is de vervolgvraag die de opdrachtgever stelt nadat hij jouw werk intern heeft besproken (week 5 en 6). De tweede helft is een natuurlijk vervolg op de eerste, geen nieuw begin.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-6 mt-0">Hoe je de tijdlijn leest</h2>
      <dl class="space-y-6 max-w-prose">
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 inline-block w-16 h-10 bg-accent rounded-sm" aria-hidden="true"></span>
          <div>
            <dt class="font-semibold m-0">Gevuld blok</dt>
            <dd class="text-ink-muted m-0">Een plenaire werkweek: de startbijeenkomst (werkweek 1) of de afronding (werkweek 7). Je komt fysiek samen en de hele groep doorloopt hetzelfde.</dd>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 inline-block w-16 h-10 bg-accent-soft border border-accent rounded-sm" aria-hidden="true"></span>
          <div>
            <dt class="font-semibold m-0">Open blok</dt>
            <dd class="text-ink-muted m-0">Een werkweek binnen de lopende opdracht voor De Vier Vaten. Je werkt aan de casus, bent voor 30 tot 60 minuten samen en doet de rest in eigen tempo.</dd>
          </div>
        </div>
        <div class="flex gap-4 items-start">
          <span class="flex-shrink-0 inline-flex w-16 h-10 items-center justify-center text-accent">
            <svg width="40" height="36" viewBox="0 0 40 36" fill="none" aria-hidden="true">
              <line x1="20" y1="4" x2="20" y2="22" stroke="currentColor" stroke-width="1.5" stroke-dasharray="2 3" />
              <path d="M16 20 L20 26 L24 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
            </svg>
          </span>
          <div>
            <dt class="font-semibold m-0">Vertaalslag-markering</dt>
            <dd class="text-ink-muted m-0">Na werkweek 4 en werkweek 6 pas je de werkwijze uit de casus toe op je eigen Business Challenge. Geen extra opdracht; juist versnelling op het werk dat je toch al doet. De tweede vertaalslag is vergelijkend: hij kijkt expliciet terug op wat je na de eerste vertaalslag in je BC daadwerkelijk hebt gedaan.</dd>
          </div>
        </div>
      </dl>
    </div>
  </section>

  <section class="py-12 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-6 mt-0">Hoe een werkweek eruitziet</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-prose mb-6">
        <div>
          <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent mb-3">
            <Icon name="users" size={20} />
          </span>
          <h3 class="mb-2 mt-0">Eén werksessie</h3>
          <p class="text-ink-muted m-0">30 tot 60 minuten in het samenwerkend-leren-blok. Je werkt aan de lopende casus, haalt feedback en bespreekt lastige keuzes met elkaar.</p>
        </div>
        <div>
          <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent mb-3">
            <Icon name="clock" size={20} />
          </span>
          <h3 class="mb-2 mt-0">2 tot 5 uur in eigen tempo</h3>
          <p class="text-ink-muted m-0">De rest pak je wanneer het uitkomt. Deze tijd betaalt zich terug in het werk dat je toch al doet voor je Business Challenge en andere vakken.</p>
        </div>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Alleen werkweek 1 en werkweek 7 zijn volledig plenair; daar zit je samen voor de startbijeenkomst en de afronding.</p>
    </div>
  </section>

  <section class="py-12 border-t border-rule">
    <div class="max-w-4xl">
      <h2 class="text-2xl md:text-3xl mb-2 mt-0">Week voor week</h2>
      <p class="text-ink-muted mb-8 max-w-prose">Elke werkweek heeft zijn eigen kop; klik voor de volledige weekpagina.</p>

      <ol class="list-none p-0 m-0 space-y-2">
        {weken.map((w) => {
          const isPlenair = Boolean(w.plenair);
          const hasVertaalslag = Boolean(w.vertaalslag);
          return (
            <li>
              <a
                href={url(`/weken/${w.slug}/`)}
                class="flex items-start gap-4 md:gap-6 border border-rule rounded-md p-5 bg-white/40 no-underline hover:border-accent hover:bg-accent-soft/30 transition-colors group"
              >
                <span class:list={[
                  'flex-shrink-0 inline-flex items-center justify-center w-14 h-14 rounded-md font-serif text-2xl',
                  isPlenair
                    ? 'bg-accent text-bg'
                    : 'bg-accent-soft text-accent border border-accent',
                ]}>
                  {w.n}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                    <h3 class="m-0 text-lg font-sans font-semibold text-ink group-hover:text-accent">{w.kop}</h3>
                    <span class="text-xs uppercase tracking-[0.12em] text-ink-muted font-medium">{w.periode}</span>
                  </div>
                  <p class="text-ink-muted m-0 mb-2">{w.oneliner}</p>
                  <div class="flex flex-wrap gap-2">
                    {isPlenair && (
                      <span class="inline-flex items-center gap-1 text-xs text-accent bg-accent-soft/60 px-2 py-0.5 rounded-sm font-medium">
                        <Icon name="users" size={12} />
                        Plenair
                      </span>
                    )}
                    {hasVertaalslag && (
                      <span class="inline-flex items-center gap-1 text-xs text-accent bg-accent-soft/60 px-2 py-0.5 rounded-sm font-medium">
                        <Icon name="target" size={12} />
                        {w.vertaalslagLabel ?? 'Vertaalslag naar je Business Challenge'}
                      </span>
                    )}
                  </div>
                </div>
                <span class="flex-shrink-0 self-center text-accent opacity-0 group-hover:opacity-100 transition-opacity">
                  <Icon name="arrow-right" size={18} />
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    </div>
  </section>

  <section class="py-12 border-t border-rule">
    <div class="max-w-5xl">
      <h2 class="text-2xl md:text-3xl mb-2 mt-0">Drie vaardigheden die door alles heen lopen</h2>
      <p class="text-ink-muted mb-8 max-w-prose">Elke werkweek zet één van deze drie centraal, maar alle drie zijn steeds in beeld. Samen vormen ze waar je aan werkt.</p>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {vaardigheden.map((v) => (
          <article class="border border-rule rounded-md p-6 bg-white/40">
            <span class="inline-flex w-11 h-11 rounded-full bg-accent-soft items-center justify-center text-accent mb-4">
              <Icon name={v.icon} size={22} />
            </span>
            <h3 class="mt-0 mb-2 text-base font-sans font-semibold text-ink">{v.titel}</h3>
            <p class="text-ink-muted text-sm m-0">{v.tekst}</p>
          </article>
        ))}
      </div>
      <p class="mt-6 text-sm m-0">
        <a href={url('/vaardigheden/')} class="inline-flex items-center gap-1">
          Lees wat elke vaardigheid concreet betekent
          <Icon name="arrow-right" size={16} />
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
