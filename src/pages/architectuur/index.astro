---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaceholderSection from '../../components/PlaceholderSection.astro';
---
<BaseLayout
  title="Programma-opbouw"
  description="De zeven werkweken, de twee casussen en de momenten waarop je terugkoppelt naar je eigen Business Challenge."
>
  <PlaceholderSection
    eyebrow="Placeholder · visuele tijdlijn volgt"
    title="Programma-opbouw"
    lede="De zeven werkweken, de twee casussen en de twee momenten waarop je het geleerde toepast op je eigen Business Challenge."
    items={[
      "Werkweek 1: plenaire kickoff, eerste zelftest, kennismaking met casus 1",
      "Werkweken 2 – 4: casus 1 (drie weken); aan het einde vertaalslag naar je eigen Business Challenge",
      "Werkweken 5 – 6: casus 2 (twee weken); opnieuw een vertaalslag naar je Business Challenge",
      "Werkweek 7: plenaire afsluiting, tweede zelftest, integratie-reflectie",
      "Visuele tijdlijn met de structuur 1 + 3 + 2 + 1 en markers voor beide vertaalslagen",
    ]}
    note="Tijdlijn wordt in stap 4 als volwaardig component uitgewerkt, met een gecomprimeerde versie in de header van elke weekpagina."
  />
</BaseLayout>
