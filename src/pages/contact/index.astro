---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Contact"
  description="Contactgegevens voor vragen over het programma."
>
  <section class="py-12 md:py-20">
    <div class="max-w-3xl">
      <h1 class="text-4xl md:text-5xl leading-tight mb-6 mt-0">Contact</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">
        Vragen over het programma kun je rechtstreeks stellen.
      </p>

      <div class="border border-rule rounded-md p-6 bg-white/40 max-w-lg">
        <p class="font-serif text-2xl m-0 mb-1">Marcel Schenkeveld</p>
        <p class="text-ink-muted m-0 mb-4">Docent Fontys Commerciële Economie</p>
        <p class="m-0">
          <a href="mailto:marcel.schenkeveld@fontys.nl">marcel.schenkeveld@fontys.nl</a>
        </p>
      </div>

      <p class="text-sm text-ink-muted border-l-2 border-accent-soft pl-4 italic mt-10 max-w-prose">
        Controleer of het getoonde Fontys-mailadres klopt; dit is voor nu ingevuld volgens de standaard Fontys-conventie.
      </p>
    </div>
  </section>
</BaseLayout>
