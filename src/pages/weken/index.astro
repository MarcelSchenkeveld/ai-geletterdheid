---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { url } from '../../lib/url.ts';

const weeks = [
  { n: 1, label: 'Kickoff', summary: 'Gezamenlijke start, eerste zelftest, kennismaking met casus 1.' },
  { n: 2, label: 'Casus 1 · week 1', summary: 'Instap in de eerste casus, gezamenlijk kader.' },
  { n: 3, label: 'Casus 1 · week 2', summary: 'Verdieping, peer review, gerichte ondersteuning.' },
  { n: 4, label: 'Casus 1 · week 3', summary: 'Afronding casus 1, vertaalslag naar eigen Business Challenge.' },
  { n: 5, label: 'Casus 2 · week 1', summary: 'Tweede casus, andere klemtoon, hoger tempo.' },
  { n: 6, label: 'Casus 2 · week 2', summary: 'Afronding casus 2, tweede vertaalslag naar je Business Challenge.' },
  { n: 7, label: 'Afsluiting', summary: 'Tweede zelftest, integratie, doorkijk naar het verdere curriculum.' },
];
---
<BaseLayout
  title="Per werkweek"
  description="Overzicht van de zeven werkweken: wat er in elke week gebeurt en wat je in eigen tempo doet."
>
  <section class="py-12 md:py-16">
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-[0.15em] text-ink-muted mb-4 m-0">Placeholder</p>
      <h1 class="text-4xl md:text-5xl leading-tight mb-6 mt-0">Per werkweek</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-10 max-w-prose">
        Wat er in elke werkweek gebeurt en wat je in eigen tempo doet. De volledige inhoud per week volgt; voor nu vind je hier het overzicht.
      </p>
    </div>

    <ol class="list-none p-0 m-0 space-y-3 max-w-3xl">
      {weeks.map((w) => (
        <li>
          <article class="border border-rule rounded-md p-5 bg-white/40">
            <div class="flex items-baseline gap-4 mb-1">
              <span class="font-serif text-2xl text-accent leading-none">Wk {w.n}</span>
              <h2 class="text-lg font-sans font-semibold m-0">{w.label}</h2>
            </div>
            <p class="text-ink-muted m-0">{w.summary}</p>
          </article>
        </li>
      ))}
    </ol>

    <p class="text-sm text-ink-muted border-l-2 border-accent-soft pl-4 italic mt-10 max-w-prose">
      Individuele weekpagina's met doel, werksessie-inhoud en eigen-tempo-werk worden in stap 4 gevuld.
    </p>
  </section>
</BaseLayout>
