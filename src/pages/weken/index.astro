---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { weken } from '../../data/weken.ts';
---
<BaseLayout
  title="Weekwijzer per werkweek"
  description="Een compacte wegwijzer per werkweek: wat we samen doen, wat je voorbereidt, wat je erna uitwerkt en waar je op kunt terugvallen."
>
  <section class="py-12 md:py-16">
    <div class="max-w-3xl">
      <p class="text-sm uppercase tracking-[0.15em] text-ink-muted mb-4 m-0">Weekwijzer</p>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-6 mt-0">Wat er elke week gebeurt</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-0 max-w-prose">
        Een compacte wegwijzer per werkweek. Eén blad, bedoeld om op maandagochtend door te lezen. Het geeft je wat we samen doen in de werksessie, wat je vooraf en erna uitwerkt, waar je bij je AI-logboek op let en welke documenten deze week bij de hand horen.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Zo gebruik je het</h2>
      <div class="space-y-4 text-lg leading-relaxed max-w-prose">
        <p class="m-0">Lees de weekwijzer aan het begin van de week. Houd hem open in je notitie-app of druk hem af. Vink voor jezelf af wat klaar is. Als iets onduidelijk blijft, stel je vraag in het Teams-kanaal of breng hem mee naar de werksessie.</p>
        <p class="m-0">De tijden zijn richtlijnen: 30 tot 60 minuten werksessie en 2 tot 5 uur eigen werk per week. Als je merkt dat je veel meer tijd kwijt bent, stel je een vraag; we hebben het programma op die bandbreedte ontworpen.</p>
        <p class="m-0">De weekwijzers vervangen niet de casusbriefing of je logboek. Ze zijn een dagelijks handvat voor je planning.</p>
      </div>
    </div>
  </section>

  <section class="py-8 md:py-10 border-t border-rule">
    <div class="max-w-4xl">
      <ol class="list-none p-0 m-0 space-y-3">
        {weken.map((w) => {
          const isPlenair = Boolean(w.plenair);
          const hasVertaalslag = Boolean(w.vertaalslag);
          return (
            <li>
              <a
                href={url(`/weken/${w.slug}/`)}
                class="flex items-start gap-4 md:gap-6 border border-rule rounded-md p-5 bg-white/40 no-underline hover:border-accent hover:bg-accent-soft/30 transition-colors group"
              >
                <span class:list={[
                  'flex-shrink-0 inline-flex items-center justify-center w-14 h-14 rounded-md font-serif text-2xl',
                  isPlenair
                    ? 'bg-accent text-bg'
                    : 'bg-accent-soft text-accent border border-accent',
                ]}>
                  {w.n}
                </span>
                <div class="flex-1 min-w-0">
                  <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1">
                    <h2 class="m-0 text-lg font-sans font-semibold text-ink group-hover:text-accent">{w.kop}</h2>
                    <span class="text-xs uppercase tracking-[0.12em] text-ink-muted font-medium">{w.periode}</span>
                  </div>
                  <p class="text-ink-muted m-0 mb-2">{w.oneliner}</p>
                  <div class="flex flex-wrap gap-2">
                    {isPlenair && (
                      <span class="inline-flex items-center gap-1 text-xs text-accent bg-accent-soft/60 px-2 py-0.5 rounded-sm font-medium">
                        <Icon name="users" size={12} />
                        Plenair
                      </span>
                    )}
                    {hasVertaalslag && (
                      <span class="inline-flex items-center gap-1 text-xs text-accent bg-accent-soft/60 px-2 py-0.5 rounded-sm font-medium">
                        <Icon name="target" size={12} />
                        {w.vertaalslagLabel ?? 'Vertaalslag naar je Business Challenge'}
                      </span>
                    )}
                  </div>
                </div>
                <span class="flex-shrink-0 self-center text-accent opacity-0 group-hover:opacity-100 transition-opacity">
                  <Icon name="arrow-right" size={18} />
                </span>
              </a>
            </li>
          );
        })}
      </ol>
    </div>
  </section>
</BaseLayout>
