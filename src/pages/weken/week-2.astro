---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(2)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doen we samen</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Een werksessie van 30 tot 60 minuten. Je pitcht in drie minuten welke twee à drie AI-toepassingen je deze week wilt inzetten en waarom. Je buur stelt je één kritische vraag. Daarna bespreken we plenair welke patronen in de toolkeuzes van de groep zitten en waar de grootste onzekerheid ligt.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doe je vóór de werksessie</h2>
      </div>
      <ol class="list-decimal pl-6 text-ink-muted space-y-3 max-w-prose">
        <li><strong class="font-medium text-ink">Lees de briefing van casus 1 en het aanvullende casusboek</strong> rustig door. Deze staan sinds einde week 1 in Teams.</li>
        <li><strong class="font-medium text-ink">Kijk een uurtje rond op een paar websites van Nederlandse craft-brouwerijen</strong> (bijvoorbeeld Brouwerij De Molen of Oedipus, of een brouwerij bij jou in de buurt). Let op hoe zij hun verhaal vertellen, wie hun klant lijkt te zijn, welke producten ze voeren. Niet samenvatten; inleven.</li>
        <li><strong class="font-medium text-ink">Bepaal welke twee à drie AI-toepassingen je deze week wilt inzetten</strong> voor de eerste stappen (marktverkenning, persona's, eerste positionering). Per tool noteer je: welke fase ga ik hiermee aanpakken, welke rol geef ik de tool, wat verwacht ik dat eruit komt.</li>
        <li><strong class="font-medium text-ink">Bereid je pitch van drie minuten voor</strong> op basis van die keuzes.</li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="arrow-right" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doe je na de werksessie</h2>
      </div>
      <p class="text-ink-muted mb-4 max-w-prose">Twee deliverables voor week 3.</p>
      <ol class="list-decimal pl-6 text-ink-muted space-y-3 max-w-prose">
        <li><strong class="font-medium text-ink">Een of twee persona's</strong> voor de doelgroep van het proefdoos-abonnement. Kies bewust welke persona's je maakt op basis van wat De Vier Vaten vraagt.</li>
        <li><strong class="font-medium text-ink">Een eerste positioneringsschets.</strong> Richtinggevende statements, geen volledig positioneringsstatement nog.</li>
      </ol>
      <p class="text-ink-muted mt-4 mb-0 max-w-prose">Alle keuzes en stappen leg je vast in je <a href={url('/ai-logboek/')}>AI-logboek</a>.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="document" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Je AI-logboek deze week</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Per serieuze inzet van AI maak je een entry. Reken op drie tot vijf entries. Belangrijk deze week: het veld "wat zou ik anders doen" vul je nadrukkelijk in. Je toolkeuze is nu nog vers en dus herzienbaar; juist nu is de reflectie waardevol.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="layers" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Bouwstenen bij deze week</h2>
      </div>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Briefing casus 1 zoals die in Teams verschijnt</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/casussen/casusboek/')}>Casusboek De Vier Vaten</a> voor extra achtergrond over de brouwerij, oprichters, assortiment, klanten, cijfers</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Je eigen <a href={url('/ai-logboek/')}>AI-logboek</a></span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Het Teams-kanaal voor vragen tussendoor</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Tijdsbeslag</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Werksessie 30 tot 60 minuten. Daarnaast circa 3 uur in eigen tempo.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="mail" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Waar je op kunt terugvallen</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">De Vier Vaten beantwoordt deze weken geen aanvullende vragen. Dat is bewust: commerciële opdrachten werken vaak met onvolledige informatie. Loop je tegen een ontbrekend feit aan, maak een plausibele aanname en leg die vast in je logboek. Blijf je steken, zet je vraag in Teams.</p>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
