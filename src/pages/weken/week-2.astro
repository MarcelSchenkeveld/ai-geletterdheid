---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(2)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In de werksessie</h2>
      </div>
      <p class="text-ink-muted mb-5 max-w-prose">Plenair, 30 tot 60 minuten. Kantelmoment: welke AI-toepassingen ga je inzetten, en waarom?</p>
      <ol class="space-y-4 max-w-prose list-none p-0 m-0">
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">1</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Drie minuten pitch</p>
            <p class="text-ink-muted m-0">Je presenteert welke twee tot drie AI-toepassingen je deze week wilt inzetten: welke fase, welke rol, welke verwachting. Kort en concreet.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">2</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Eén kritische vraag terug</p>
            <p class="text-ink-muted m-0">Een medestudent stelt één pittige vraag bij jouw keuze. Niet oordelen, wel scherpen.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">3</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Patronen en afspraken voor deze week</p>
            <p class="text-ink-muted m-0">Je docent maakt zichtbaar welke patronen in de toolkeuzes opvallen en wat we deze week extra in het logboek willen zien.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In eigen tempo</h2>
      </div>
      <p class="text-ink-muted mb-6 max-w-prose">Indicatief 2 tot 5 uur. Verdeeld over oriëntatie, inhoudelijk werk en documentatie.</p>

      <h3 class="mt-0 mb-3 text-base font-sans font-semibold text-ink">Vóór de werksessie</h3>
      <ul class="list-disc pl-6 text-ink-muted mb-8 space-y-2 max-w-prose">
        <li>Lees de briefing van <a href={url('/casussen/')}>De Vier Vaten</a> rustig door (volgt via Teams na de startbijeenkomst).</li>
        <li>Oriënteer je een uurtje op een paar bestaande craft-brouwerijwebsites; bedenk vast waar jouw vragen liggen. Niet uitwerken, wel scherp worden.</li>
      </ul>

      <h3 class="mt-0 mb-3 text-base font-sans font-semibold text-ink">Na de werksessie</h3>
      <ul class="list-disc pl-6 text-ink-muted space-y-2 max-w-prose">
        <li>Werk één of twee persona's uit voor de doelgroep van het proefdoos-abonnement.</li>
        <li>Schets een eerste positionering (richtinggevende statements, nog geen definitief statement).</li>
        <li>Documenteer je AI-keuzes in je <a href={url('/ai-logboek/')}>AI-logboek</a>: welke prompt, welke output, welke nabewerking, en wat zou je in een tweede ronde anders doen? Vul dat laatste veld deze week nadrukkelijk in; de toolkeuze is nog vers en herzienbaar.</li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Waar gaat dit naartoe</h2>
      <p class="text-lg leading-relaxed max-w-prose m-0">
        Dit is de start van drie weken werken voor De Vier Vaten. In <a href={url('/weken/week-3/')}>werkweek 3</a> ga je dieper in op idee-ontwikkeling en alternatieven; in <a href={url('/weken/week-4/')}>werkweek 4</a> lever je het mini-plan op en maak je de eerste vertaalslag naar je eigen Business Challenge.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Bronnen voor deze week</h2>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="layers" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/casussen/')}>De casus: Brouwerij De Vier Vaten</a> · briefing en context</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="document" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/casussen/casusboek/')}>Casusboek</a> · achtergrond bij de opdrachtgever</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/ai-logboek/')}>AI-logboek</a> · vaste velden per entry</span>
        </li>
      </ul>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
