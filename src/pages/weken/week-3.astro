---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(3)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In de werksessie</h2>
      </div>
      <p class="text-ink-muted mb-5 max-w-prose">Plenair, 30 tot 60 minuten. Je werkt in tweetallen volgens een kort patroon, met AI als tegenstem.</p>
      <ol class="space-y-4 max-w-prose list-none p-0 m-0">
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">1</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Je docent modelleert vooraf</p>
            <p class="text-ink-muted m-0">Vijf minuten waarin het werkpatroon hardop wordt voorgedaan: zo ziet de vraag eruit, zo lees je AI-output, zo beslis je wat je overneemt.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">2</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Formuleer een idee of richting</p>
            <p class="text-ink-muted m-0">In tweetallen. Eén voorgenomen keuze voor De Vier Vaten (propositie, positionering, kanaal), kort en concreet.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">3</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Vraag AI om drie tegenargumenten</p>
            <p class="text-ink-muted m-0">Laat AI expliciet tegen jouw keuze ingaan: welke invalshoeken of bezwaren zie jij niet? Niet om jezelf te overtuigen, wel om scherp te worden.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">4</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Samen wegen wat je overneemt</p>
            <p class="text-ink-muted m-0">Bespreek in het tweetal welk tegenargument hout snijdt, wat je overneemt in je eigen aanpak, en waarom je iets juist níet overneemt.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In eigen tempo</h2>
      </div>
      <p class="text-ink-muted mb-5 max-w-prose">Indicatief 2 tot 5 uur. De meeste tijd zit in het daadwerkelijk denken met en zonder AI, niet in het lezen erover.</p>
      <ul class="list-disc pl-6 text-ink-muted space-y-2 max-w-prose">
        <li>Werk je propositie-canvas uit voor het proefdoos-abonnement.</li>
        <li>Kies een eerste richting voor de positionering en een eerste opzet voor de kanaalmix.</li>
        <li>Wissel bewust af tussen denken-met-AI en denken-zonder-AI. Laat minstens één creatieve fase eerst dertig minuten zonder AI lopen, pas daarna AI erbij als tegenstem.</li>
        <li>Leg in je <a href={url('/ai-logboek/')}>AI-logboek</a> vast wat AI je opleverde dat je zelf niet had bedacht, en wat je bewust niet hebt overgenomen.</li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Waar gaat dit naartoe</h2>
      <p class="text-lg leading-relaxed max-w-prose m-0">
        Deze week is de inhoudelijke verdieping. In <a href={url('/weken/week-4/')}>werkweek 4</a> rond je het mini-plan voor De Vier Vaten af en maak je de eerste vertaalslag naar je eigen Business Challenge.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Bronnen voor deze week</h2>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="layers" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/casussen/')}>De casus: Brouwerij De Vier Vaten</a></span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="document" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/ai-logboek/')}>AI-logboek</a></span>
        </li>
      </ul>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
