---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(7)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doen we samen</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Een plenaire afsluiting van zestig minuten, fysiek. Drie dingen: we kijken naar hoe de groep op de zelftest is verschoven tussen week 1 en week 7, je deelt in een drietal één moment uit de zes weken dat anders was dan je dacht, en je formuleert schriftelijk een vervolgcommitment dat je kort in een tweetal en plenair uitspreekt.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doe je vóór de afsluiting</h2>
      </div>
      <ol class="list-decimal pl-6 text-ink-muted space-y-3 max-w-prose">
        <li><strong class="font-medium text-ink">Vul de tweede <a href={url('/zelftest/')}>zelftest</a> in</strong> via de link in Teams. Deadline: minstens 48 uur vóór de bijeenkomst, zodat het groepsbeeld klaar is voor de zaal.</li>
        <li><strong class="font-medium text-ink">Leg je AI-logboek over zes weken binnen handbereik</strong> plus je twee vertaalslag-notities. Je hoeft ze niet te lezen; je wilt ze kunnen openslaan als je één moment zoekt dat je in de drietalronde wilt delen.</li>
        <li><strong class="font-medium text-ink">Kies vooraf één moment.</strong> In de zes weken bij De Vier Vaten of in een van je twee vertaalslagen was er iets dat anders was dan je dacht. Geen succesverhaal, geen klacht; een verschuiving in je werkwijze of denken. Eén zin volstaat.</li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="arrow-right" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doe je na de afsluiting</h2>
      </div>
      <ol class="list-decimal pl-6 text-ink-muted space-y-3 max-w-prose">
        <li><strong class="font-medium text-ink">Plaats je vervolgcommitment in Portflow</strong> (foto van het werkblad of overgetypt), onder de programma-leeruitkomst over eigenaarschap en verantwoord AI-gebruik, en optioneel onder TG2-PPO.</li>
        <li><strong class="font-medium text-ink">Rond je Portflow-landing af</strong> als je dat in week 4 en week 6 nog niet volledig hebt gedaan: de twee vertaalslag-notities en het AI-logboek over zes weken horen er bij, gekoppeld aan de programma-leeruitkomst over eigenaarschap. Voor de andere twee leeruitkomsten van dit programma geldt: koppel wat relevant is aan TG2-leeruitkomsten waar dat in je eigen route past.</li>
        <li><strong class="font-medium text-ink">Houd het Teams-kanaal open voor vervolgvragen</strong> in de twee weken na de afsluiting.</li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="document" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Je AI-logboek deze week</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Geen nieuwe verplichte entries; het logboek is af. Je gebruikt hem als geheugen voor de drietalronde en voor je vervolgcommitment.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="layers" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Bouwstenen bij deze week</h2>
      </div>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Je twee vertaalslag-notities (uit week 4 en week 6) in Portflow</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Je <a href={url('/ai-logboek/')}>AI-logboek</a> over zes weken</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>De tweede <a href={url('/zelftest/')}>zelftest</a> via Teams</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Tijdsbeslag</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Afsluiting 60 minuten. Daarnaast circa 1 tot 2 uur in eigen tempo (tweede zelftest vooraf, Portflow-landing erna).</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="mail" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Waar je op kunt terugvallen</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Als je in de drietalronde een veilig moment kiest ("ik heb veel geleerd"), krijg je van je peers of van mij waarschijnlijk één doorvraag. Niet bedoeld als val; bedoeld om iets concreets op tafel te krijgen. Denk vooraf even aan één beslissing in week 5 die je in week 2 nog niet zou hebben genomen. Voor je vervolgcommitment geldt: concreet werkt ("vanaf maandag begin ik elke werksessie met een toolkeuze van twee minuten in mijn logboek"), een algemeenheid werkt niet ("ik ga AI bewuster gebruiken").</p>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
