---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(5)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doen we samen</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Een werksessie van 30 tot 45 minuten (korter dan in week 2). Je pitcht in twee minuten welke twee à drie AI-toepassingen je voor de vervolgvraag wilt inzetten en wat er anders is dan in casus 1. Je buur stelt je één kritische vraag: waarom werkte dit toen wel en nu niet, of waarom past dit nu wel en toen niet? Plenair kijken we naar de patronen in hoe de groep herijkt.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doe je vóór de werksessie</h2>
      </div>
      <ol class="list-decimal pl-6 text-ink-muted space-y-3 max-w-prose">
        <li><strong class="font-medium text-ink">Lees de vervolgbriefing voor casus 2</strong> in Teams (beschikbaar einde week 4). De Vier Vaten vraagt twee dingen: een retentie-aanpak voor abonnees en drie wervingsscenarios voor de eerste tweehonderd abonnees, met een onderbouwd advies.</li>
        <li><strong class="font-medium text-ink">Blader je AI-logboek van de afgelopen drie weken door.</strong> Stel jezelf één vraag en beantwoord die in maximaal vijf zinnen: welke toolkeuze of werkwijze uit casus 1 wil ik aanhouden, welke wil ik dit keer anders doen, en waarom? Deze vijf zinnen zijn je startpunt voor de werksessie.</li>
        <li><strong class="font-medium text-ink">Bedenk waar het werk deze casus echt anders wordt.</strong> In casus 1 bouwde je op; in casus 2 wordt gevraagd om alternatieven te wegen en een keuze te onderbouwen. Welke AI-toepassingen passen beter bij wegen en kiezen dan bij opbouwen?</li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="arrow-right" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Wat doe je na de werksessie</h2>
      </div>
      <p class="text-ink-muted mb-4 max-w-prose">Twee deliverables voor week 6.</p>
      <ol class="list-decimal pl-6 text-ink-muted space-y-3 max-w-prose">
        <li><strong class="font-medium text-ink">Drie wervingsscenarios in concept</strong> (samen één à anderhalve A4).</li>
        <li><strong class="font-medium text-ink">Een eerste retentie-aanpak</strong> (drie of vier kernkeuzes om abonnees te binden).</li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="document" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Je AI-logboek deze week</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Per serieuze inzet van AI een entry. Deze week is één veld extra belangrijk: "wat doe ik nu anders dan in casus 1". Dit veld voedt straks je tweede vertaalslag-notitie in week 6, waarin je expliciet vergelijkt met je eerste vertaalslag.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="layers" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Bouwstenen bij deze week</h2>
      </div>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Vervolgbriefing casus 2 zoals die in Teams verschijnt</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Je eigen mini-plan en vertaalslag-notitie 1 uit casus 1</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Je <a href={url('/ai-logboek/')}>AI-logboek</a> van de afgelopen drie weken</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/casussen/casusboek/')}>Casusboek De Vier Vaten</a> voor aanvullende achtergrond</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Tijdsbeslag</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Werksessie 30 tot 45 minuten. Daarnaast circa 3 uur in eigen tempo. Iets lichter dan week 4 omdat je opdrachtgever al kent.</p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="mail" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Waar je op kunt terugvallen</h2>
      </div>
      <p class="text-ink-muted max-w-prose m-0">Als je pitch "hetzelfde als casus 1" wordt, is dat waarschijnlijk niet waar: de aard van de vraag is veranderd. Kijk je logboek door op momenten waarop AI in casus 1 iets níet goed oploste; de kans is groot dat precies daar nu een andere tool of werkwijze past. Voor concrete retentie- en scenario-vragen: in Teams is het vraagkanaal de eerste plek.</p>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
