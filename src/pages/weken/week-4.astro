---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(4)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
        <span class="inline-flex items-center gap-1 text-xs text-accent bg-accent-soft/60 px-2 py-0.5 rounded-sm font-medium">
          <Icon name="target" size={12} />
          Vertaalslag naar je Business Challenge
        </span>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In de werksessie</h2>
      </div>
      <p class="text-ink text-lg leading-relaxed max-w-prose m-0">
        Twee dingen deze week: we ronden <a href={url('/casussen/casus-1/')}>casus 1</a> af en we zetten de eerste vertaalslag naar je eigen Business Challenge. Dat laatste is het didactische hart: wat van de werkwijze uit deze casus ga je meenemen naar je lopende BC-werk, en hoe maak je dat zichtbaar in je eigen product?
      </p>
      <p class="text-sm text-ink-muted italic mt-4 max-w-prose border-l-2 border-accent-soft pl-4 m-0">
        De precieze inhoud van de werksessie wordt door je docent uitgewerkt op basis van de casusbriefing.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="target" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">Eerste vertaalslag naar je Business Challenge</h2>
      </div>
      <p class="text-ink-muted mb-5 max-w-prose">
        Je kijkt naar je lopende Business Challenge met de werkwijze uit casus 1 in handen en stelt jezelf drie vragen:
      </p>
      <ol class="space-y-4 list-none p-0 m-0 max-w-prose">
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">1</span>
          <p class="m-0 text-ink">Welke AI-toepassing of werkwijze uit casus 1 zou in mijn BC werkelijk verschil maken?</p>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">2</span>
          <p class="m-0 text-ink">Hoe ga ik dat deze week concreet toepassen in het werk dat ik toch al doe?</p>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">3</span>
          <p class="m-0 text-ink">Hoe maak ik in mijn BC-product zichtbaar dat ik die werkwijze bewust heb ingezet?</p>
        </li>
      </ol>
      <p class="text-ink-muted mt-6 max-w-prose m-0">
        Je <a href={url('/ai-logboek/')}>AI-logboek</a> is hierbij je bronmateriaal: daar zie je wat je in de casus hebt geprobeerd en wat werkte.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In eigen tempo</h2>
      </div>
      <ul class="list-disc pl-6 text-ink-muted space-y-2 max-w-prose">
        <li>Rond je bijdrage aan casus 1 af volgens wat in de casusbriefing is afgesproken.</li>
        <li>Pas de werkwijze toe op je Business Challenge en leg kort vast wat er gebeurt.</li>
        <li>Schrijf een korte vertaalslag-entry in je AI-logboek (veld 4 en 5 vullen elkaar hier goed aan).</li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Waar gaat dit naartoe</h2>
      <p class="text-lg leading-relaxed max-w-prose m-0">
        In <a href={url('/weken/week-5/')}>werkweek 5</a> pak je een tweede casus op in een ander domein, met de ervaring uit casus 1 op zak. Het patroon herhaalt, maar je bent niet meer dezelfde.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Bronnen voor deze week</h2>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="layers" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/casussen/casus-1/')}>Casus 1</a></span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="document" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/ai-logboek/')}>AI-logboek</a> · je bronmateriaal voor de vertaalslag</span>
        </li>
      </ul>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
