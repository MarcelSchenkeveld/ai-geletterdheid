---
import BaseLayout from '../../layouts/BaseLayout.astro';
import MiniTijdlijn from '../../components/MiniTijdlijn.astro';
import WeekNav from '../../components/WeekNav.astro';
import Icon from '../../components/Icon.astro';
import { url } from '../../lib/url.ts';
import { getWeek } from '../../data/weken.ts';

const week = getWeek(1)!;
---
<BaseLayout
  title={`Werkweek ${week.n}: ${week.kop}`}
  description={week.oneliner}
>
  <section class="py-10 md:py-14">
    <div class="max-w-3xl">
      <div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-4">
        <p class="text-sm uppercase tracking-[0.15em] text-ink-muted m-0">Werkweek {week.n}</p>
        <p class="text-sm text-ink-muted m-0">{week.periode}</p>
      </div>
      <h1 class="text-4xl md:text-5xl leading-[1.05] mb-5 mt-0">{week.kop}</h1>
      <p class="text-xl text-ink-muted leading-relaxed mb-8 max-w-prose">{week.oneliner}</p>
      <MiniTijdlijn current={week.n} />
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="users" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In de werksessie</h2>
      </div>
      <p class="text-ink-muted mb-5 max-w-prose">Plenair, fysiek, tot 60 minuten. Drie delen die aan het einde samenkomen.</p>
      <ol class="space-y-4 max-w-prose list-none p-0 m-0">
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">1</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Spiegel via de zelftest</p>
            <p class="text-ink-muted m-0">We bekijken samen wat de groepsuitkomst van de zelftest laat zien. Je legt je eigen antwoorden ernaast en herkent waar jouw groeiruimte zit.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">2</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Programma in zeven werkweken</p>
            <p class="text-ink-muted m-0">Een heldere doorloop van de tijdlijn: wat doen we wanneer, wat is het ritme, wat krijg je van mij en wat vraag ik van jou.</p>
          </div>
        </li>
        <li class="flex gap-5 items-start">
          <span class="font-serif text-2xl text-accent leading-none pt-1 flex-shrink-0">3</span>
          <div>
            <p class="font-medium text-ink m-0 mb-1">Je eigen voornemen</p>
            <p class="text-ink-muted m-0">Je schrijft in een paar minuten op wat je wilt leren, bespreekt dat in een tweetal en zegt je voornemen in één zin plenair uit.</p>
          </div>
        </li>
      </ol>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <div class="flex items-center gap-3 mb-5">
        <span class="inline-flex w-10 h-10 rounded-full bg-accent-soft items-center justify-center text-accent">
          <Icon name="clock" size={20} />
        </span>
        <h2 class="text-2xl md:text-3xl mt-0 mb-0">In eigen tempo</h2>
      </div>
      <p class="text-ink-muted mb-6 max-w-prose">Indicatief 2 tot 5 uur. Verdeeld over voorbereiding en uitloop.</p>

      <h3 class="mt-0 mb-3 text-base font-sans font-semibold text-ink">Vóór de werksessie</h3>
      <ul class="list-disc pl-6 text-ink-muted mb-8 space-y-2 max-w-prose">
        <li>Vul de <a href={url('/zelftest/')}>zelftest</a> in, uiterlijk 48 uur vóór de werksessie. Zo kan ik een groepsoverzicht voorbereiden dat we in de sessie bespreken.</li>
        <li>Denk kort na over waar je nu staat met AI in je werk, zodat het voornemen straks niet uit het niets hoeft te komen.</li>
      </ul>

      <h3 class="mt-0 mb-3 text-base font-sans font-semibold text-ink">Direct na de werksessie</h3>
      <ul class="list-disc pl-6 text-ink-muted space-y-2 max-w-prose">
        <li>Binnen 24 uur ontvang je in het Teams-kanaal een bericht met de briefing van casus 1 en de instructie voor je <a href={url('/ai-logboek/')}>AI-logboek</a>.</li>
        <li>Lees de briefing van casus 1 door, zodat je de werksessie van werkweek 2 scherp instapt.</li>
        <li>Zet je AI-logboek op (kies een medium dat bij je past) en schrijf één testentry over iets wat je deze week al met AI hebt gedaan.</li>
        <li>Formuleer één concrete vraag waarmee je werkweek 2 wilt beginnen.</li>
      </ul>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Waar gaat dit naartoe</h2>
      <p class="text-lg leading-relaxed max-w-prose m-0">
        Na de startbijeenkomst pakken we in <a href={url('/weken/week-2/')}>werkweek 2</a> de eerste casus op. Je hebt dan al kennisgemaakt met de werkwijze, je hebt een logboek en een eigen voornemen. Dat zijn de haakjes waaraan de rest van het programma hangt.
      </p>
    </div>
  </section>

  <section class="py-10 border-t border-rule">
    <div class="max-w-3xl">
      <h2 class="text-2xl md:text-3xl mb-4 mt-0">Bronnen voor deze week</h2>
      <ul class="space-y-3 list-none p-0 m-0 max-w-prose">
        <li class="flex items-start gap-3">
          <Icon name="check" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/zelftest/')}>Zelftest</a> · in te vullen uiterlijk 48 uur vóór de startbijeenkomst</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="document" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span><a href={url('/ai-logboek/')}>AI-logboek</a> · uitleg en opzet</span>
        </li>
        <li class="flex items-start gap-3">
          <Icon name="layers" size={18} class="text-accent flex-shrink-0 mt-1" />
          <span>Briefing casus 1 · volgt via Teams-bericht direct na de startbijeenkomst</span>
        </li>
      </ul>
    </div>
  </section>

  <WeekNav current={week.n} />
</BaseLayout>
